/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model ledger_entries {
  id                   String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  club_id              String                @db.Uuid
  member_id            String                @db.Uuid
  delta                Decimal               @db.Decimal(15, 2)
  balance_after        Decimal               @db.Decimal(15, 2)
  reason               String                @db.VarChar(32)
  description          String?
  session_id           String?               @db.Uuid
  transfer_id          String?               @db.Uuid
  dispute_id           String?               @db.Uuid
  actor_user_id        String?               @db.Uuid
  created_at           DateTime              @default(now()) @db.Timestamptz(6)
  users                users?                @relation(fields: [actor_user_id], references: [id], onUpdate: NoAction)
  clubs                clubs                 @relation(fields: [club_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  disputes             disputes?             @relation(fields: [dispute_id], references: [id], onUpdate: NoAction)
  club_members         club_members          @relation(fields: [member_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  sessions             sessions?             @relation(fields: [session_id], references: [id], onUpdate: NoAction)
  settlement_transfers settlement_transfers? @relation(fields: [transfer_id], references: [id], onUpdate: NoAction)

  @@index([club_id, created_at], map: "idx_ledger_club_time")
  @@index([member_id, created_at], map: "idx_ledger_member_time")
}

model member_aliases {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  club_member_id String       @db.Uuid
  source         String       @db.VarChar(32)
  alias_name     String       @db.VarChar(64)
  alias_id       String?      @db.VarChar(32)
  created_at     DateTime     @default(now()) @db.Timestamptz(6)
  club_members   club_members @relation(fields: [club_member_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([source, alias_name, alias_id])
  @@index([source, alias_name], map: "idx_member_aliases_lookup")
  @@index([club_member_id], map: "idx_member_aliases_member")
}

