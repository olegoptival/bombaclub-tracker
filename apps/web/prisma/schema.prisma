/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model club_members {
  id                                                                     String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  club_id                                                                String                 @db.Uuid
  user_id                                                                String                 @db.Uuid
  role                                                                   String                 @default("player") @db.VarChar(16)
  nickname                                                               String                 @db.VarChar(64)
  current_balance                                                        Decimal                @default(0) @db.Decimal(15, 2)
  status                                                                 String                 @default("active") @db.VarChar(16)
  inactive_reason                                                        String?
  status_changed_at                                                      DateTime               @default(now()) @db.Timestamptz(6)
  status_changed_by                                                      String?                @db.Uuid
  joined_at                                                              DateTime               @default(now()) @db.Timestamptz(6)
  clubs                                                                  clubs                  @relation(fields: [club_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_club_members_status_changed_byTousers                            users?                 @relation("club_members_status_changed_byTousers", fields: [status_changed_by], references: [id], onUpdate: NoAction)
  users_club_members_user_idTousers                                      users                  @relation("club_members_user_idTousers", fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  ledger_entries                                                         ledger_entries[]
  member_aliases                                                         member_aliases[]
  session_participants                                                   session_participants[]
  settlement_transfers_settlement_transfers_from_member_idToclub_members settlement_transfers[] @relation("settlement_transfers_from_member_idToclub_members")
  settlement_transfers_settlement_transfers_to_member_idToclub_members   settlement_transfers[] @relation("settlement_transfers_to_member_idToclub_members")

  @@unique([club_id, nickname])
  @@unique([club_id, user_id])
  @@index([club_id], map: "idx_club_members_club")
  @@index([club_id, status], map: "idx_club_members_status")
  @@index([user_id], map: "idx_club_members_user")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model clubs {
  id                                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                               String               @db.VarChar(128)
  slug                               String               @unique @db.VarChar(64)
  created_by                         String               @db.Uuid
  settlement_period                  String               @default("manual") @db.VarChar(16)
  required_aliases                   String[]             @default([])
  dispute_window_days                Int                  @default(7)
  created_at                         DateTime             @default(now()) @db.Timestamptz(6)
  updated_at                         DateTime             @default(now()) @db.Timestamptz(6)
  club_members                       club_members[]
  users_clubs_created_byTousers      users                @relation("clubs_created_byTousers", fields: [created_by], references: [id], onUpdate: NoAction)
  ledger_entries                     ledger_entries[]
  sessions                           sessions[]
  settlement_periods                 settlement_periods[]
  users_users_current_club_idToclubs users[]              @relation("users_current_club_idToclubs")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
