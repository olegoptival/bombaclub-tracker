# === Database ===
POSTGRES_USER=poker
POSTGRES_PASSWORD=poker_dev_pwd
POSTGRES_DB=poker_tracker
DATABASE_URL=postgresql://poker:poker_dev_pwd@localhost:5432/poker_tracker

# === Redis ===
REDIS_URL=redis://localhost:6379

# === MinIO (S3-compatible) ===
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=poker-screenshots
S3_FORCE_PATH_STYLE=true

# === NextAuth (will be filled at Stage 3) ===
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# === Bootstrap super-admin ===
SUPERADMIN_LOGIN=admin
SUPERADMIN_PASSWORD=change_me_after_first_login

# === Anthropic API (for OCR, Stage 4) ===
ANTHROPIC_API_KEY=

# === Mailpit (dev SMTP) ===
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@bombaclub.live

# === App ===
NODE_ENV=development
LOG_LEVEL=debug
